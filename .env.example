# ============================================================
# Fluo Governance — Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# --- Database ---
DATABASE_URL="postgresql://fluo:your_password@localhost:5432/fluo_governance"
DB_PASSWORD="your_password"

# --- Backend ---
PORT=3001
NODE_ENV=development
JWT_SECRET="your_super_secret_jwt_key_min_32_chars"
JWT_EXPIRES_IN="24h"
REFRESH_TOKEN_EXPIRES_IN="7d"
CORS_ORIGIN="http://localhost:5173,http://localhost:5174,https://fluodelivery.com,https://app.fluodelivery.com"

# --- OpenAI (AI Reporting) ---
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o"

# --- Email (Resend) ---
RESEND_API_KEY="re_..."
EMAIL_FROM="Fluo Governance <noreply@fluodelivery.com>"

# --- Email (SMTP alternative to Resend) ---
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="your@email.com"
# SMTP_PASS="your_app_password"

# --- Frontend URLs (used by backend for email links) ---
APP_URL="http://localhost:5174"
LANDING_URL="http://localhost:5173"

# --- Frontend (Landing) ---
VITE_API_URL="http://localhost:3001"
VITE_APP_URL="http://localhost:5174"

# --- Frontend (App) ---
VITE_API_URL="http://localhost:3001"
VITE_APP_NAME="Fluo Governance"
